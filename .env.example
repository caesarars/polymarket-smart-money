PORT=3000
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://polymarket:polymarket@localhost:5432/polymarket?schema=public
REDIS_URL=redis://localhost:6379

POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMART_WALLET_SCORE_THRESHOLD=75

# Auto-pipeline scheduler. 0 = disabled. 15 = run every 15 minutes.
PIPELINE_INTERVAL_MINUTES=0
PIPELINE_TOP_MARKETS=20
PIPELINE_TRADES_PER_MARKET=100
# Optional category lock — e.g. "Crypto" — to crawl one category only.
# Leave commented out to crawl top markets across all categories.
# PIPELINE_CATEGORY=Crypto

# Postgres credentials used by docker-compose. The DATABASE_URL above is for
# local development; in docker compose the app overrides it to use the
# `postgres` service hostname.
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket
