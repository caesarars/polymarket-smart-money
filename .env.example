# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database & Cache
DATABASE_URL=postgresql://polymarket:polymarket@127.0.0.1:5432/polymarket?schema=public
REDIS_URL=redis://127.0.0.1:6379

# Polymarket APIs
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Binance
BINANCE_WS_URL=wss://fstream.binance.com/stream

# Telegram (optional — alerts are logged but not sent when unset)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Smart wallet alerting
SMART_WALLET_SCORE_THRESHOLD=75

# BTC Signal / Edge detection
EDGE_THRESHOLD=0.07
MIN_LIQUIDITY=1000
MIN_SPREAD_MAX=0.05
ALERT_COOLDOWN_SECONDS=60

# Pipeline scheduler (0 = disabled)
PIPELINE_INTERVAL_MINUTES=0
PIPELINE_TOP_MARKETS=20
PIPELINE_TRADES_PER_MARKET=100
PIPELINE_CATEGORY=

# Docker Compose overrides (used by docker-compose.yml)
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket
