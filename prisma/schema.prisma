generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Market {
  id            String    @id @default(cuid())
  polymarketId  String    @unique
  question      String
  slug          String?   @unique
  category      String?
  endDate       DateTime?
  volume        Float     @default(0)
  tokenYes      String?
  tokenNo       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trades            WalletTrade[]
  orderbookSnaps    OrderbookSnapshot[]
  btcMarketSnaps    BtcMarketSnapshot[]
  alerts            AlertLog[]
  btcSignals        BtcSignal[]

  @@index([isActive])
  @@index([endDate])
  @@index([category])
}

model Wallet {
  id            String   @id @default(cuid())
  address       String   @unique
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  totalVolume   Float    @default(0)
  realizedPnl   Float    @default(0)
  winRate       Float    @default(0)
  smartScore    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades  WalletTrade[]
  scores  WalletScore[]
  alerts  AlertLog[]

  @@index([smartScore])
  @@index([lastSeenAt])
}

model WalletTrade {
  id             String   @id @default(cuid())
  walletAddress  String
  marketId       String?
  tokenId        String
  side           String
  price          Float
  size           Float
  timestamp      DateTime
  rawJson        Json

  wallet  Wallet  @relation(fields: [walletAddress], references: [address], onDelete: Cascade)
  market  Market? @relation(fields: [marketId], references: [id])

  @@index([walletAddress])
  @@index([marketId])
  @@index([tokenId])
  @@index([timestamp])
}

model WalletScore {
  id                   String   @id @default(cuid())
  walletAddress        String
  pnlScore             Float    @default(0)
  timingScore          Float    @default(0)
  consistencyScore     Float    @default(0)
  specializationScore  Float    @default(0)
  liquidityScore       Float    @default(0)
  totalScore           Float    @default(0)
  createdAt            DateTime @default(now())

  wallet Wallet @relation(fields: [walletAddress], references: [address], onDelete: Cascade)

  @@index([walletAddress])
  @@index([totalScore])
  @@index([createdAt])
}

model AlertLog {
  id             String   @id @default(cuid())
  walletAddress  String?
  marketId       String?
  signalId       String?
  side           String?
  cooldownKey    String?
  message        String
  sentAt         DateTime @default(now())

  wallet  Wallet?  @relation(fields: [walletAddress], references: [address], onDelete: Cascade)
  market  Market?  @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([sentAt])
  @@index([marketId])
  @@index([side])
  @@index([cooldownKey])
}

model OrderbookSnapshot {
  id        String   @id @default(cuid())
  marketId  String
  tokenId   String
  bestBid   Float
  bestAsk   Float
  spread    Float
  timestamp DateTime
  rawJson   Json

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([tokenId])
  @@index([timestamp])
}

model BtcMarketSnapshot {
  id        String   @id @default(cuid())
  marketId  String
  tokenId   String
  bestBid   Decimal  @db.Decimal(18, 8)
  bestAsk   Decimal  @db.Decimal(18, 8)
  midPrice  Decimal  @db.Decimal(18, 8)
  spread    Decimal  @db.Decimal(18, 8)
  timestamp DateTime
  rawJson   Json

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([timestamp])
}

model BtcSignal {
  id                   String   @id @default(cuid())
  marketId             String
  side                 String
  polymarketProbability Decimal  @db.Decimal(18, 8)
  modelProbability     Decimal  @db.Decimal(18, 8)
  edge                 Decimal  @db.Decimal(18, 8)
  confidence           String
  reason               String
  timestamp            DateTime @default(now())
  rawJson              Json

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([timestamp])
  @@index([side])
}
